{
  "name": "felixel-play",
  "version": "1.0.0",
  "description": "High-End Gaming Launcher für Wii, Wii U und Switch Emulatoren",
  "main": "main.js",
  "scripts": {
    "tw:build": "npx @tailwindcss/cli -i ./tailwind.input.css -o ./tailwind.css --minify",
    "tw:watch": "npx @tailwindcss/cli -i ./tailwind.input.css -o ./tailwind.css --watch",
    "start": "npm run tw:build && electron ."
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "electron": "^41.2.2",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "node-hid": "^3.3.0"
  }
}
